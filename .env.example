# ============================================================
# GRID — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=grid
DB_USER=grid_user
DB_PASSWORD=changeme

# --- API Keys ---
FRED_API_KEY=your_fred_api_key_here

# --- Logging ---
LOG_LEVEL=INFO
ENVIRONMENT=development

# --- Pull Schedule (cron format) ---
PULL_SCHEDULE_FRED=0 18 * * 1-5
PULL_SCHEDULE_YFINANCE=30 18 * * 1-5
PULL_SCHEDULE_BLS=0 9 * * *
