# ============================================================
# GRID — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=grid
DB_USER=grid_user
DB_PASSWORD=changeme

# --- API Keys ---
FRED_API_KEY=your_fred_api_key_here

# --- Logging ---
LOG_LEVEL=INFO
ENVIRONMENT=development

# --- Pull Schedule (cron format) ---
PULL_SCHEDULE_FRED=0 18 * * 1-5
PULL_SCHEDULE_YFINANCE=30 18 * * 1-5
PULL_SCHEDULE_BLS=0 9 * * *

# --- Auth (REQUIRED for production) ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
GRID_JWT_SECRET=
# Generate with: python -c "from passlib.context import CryptContext; print(CryptContext(schemes=['bcrypt']).hash('your-password'))"
GRID_MASTER_PASSWORD_HASH=

# --- International APIs ---
KOSIS_API_KEY=your_kosis_key_here
COMTRADE_API_KEY=your_comtrade_key_here
JQUANTS_EMAIL=your_email_here
JQUANTS_PASSWORD=your_password_here

# --- Physical / Alt Data ---
USDA_NASS_API_KEY=your_usda_nass_key_here
NOAA_TOKEN=your_noaa_token_here
EIA_API_KEY=your_eia_key_here
GDELT_API_KEY=your_gdelt_key_here

# --- Pull schedules for v2 sources ---
PULL_SCHEDULE_INTERNATIONAL=0 20 * * 1-5
PULL_SCHEDULE_TRADE=0 3 * * 0
PULL_SCHEDULE_PHYSICAL=0 4 1 * *
PULL_SCHEDULE_ALTDATA=30 20 * * 1-5

# --- llama.cpp (local LLM inference — replaces Ollama) ---
LLAMACPP_BASE_URL=http://localhost:8080
LLAMACPP_ENABLED=true
LLAMACPP_TIMEOUT_SECONDS=120
LLAMACPP_CHAT_MODEL=hermes
LLAMACPP_EMBED_MODEL=hermes

# --- Ollama (deprecated — use llama.cpp) ---
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_ENABLED=false

# --- TradingAgents (multi-agent debate system) ---
AGENTS_ENABLED=true
AGENTS_LLM_PROVIDER=llamacpp
AGENTS_LLM_MODEL=auto
AGENTS_SCHEDULE_ENABLED=true
AGENTS_SCHEDULE_CRON=0 17 * * 1-5
AGENTS_DEFAULT_TICKER=SPY
AGENTS_DEBATE_ROUNDS=1

# --- Autoresearch (self-improvement loop) ---
# Cron schedule for autonomous hypothesis generation/refinement
AUTORESEARCH_ENABLED=true
AUTORESEARCH_CRON=0 2 * * 1-5
AUTORESEARCH_MAX_ITER=5
AUTORESEARCH_LAYER=REGIME

# --- Market Briefings ---
BRIEFING_CRON_DAILY=0 6 * * 1-5
BRIEFING_CRON_WEEKLY=0 7 * * 1

# --- Email Alerts ---
ALERT_EMAIL_ENABLED=true
ALERT_EMAIL_TO=stepdadfinance@gmail.com
ALERT_EMAIL_FROM=grid-alerts@grid-svr
ALERT_SMTP_HOST=localhost
ALERT_SMTP_PORT=25
ALERT_SMTP_USER=
ALERT_SMTP_PASSWORD=
ALERT_SMTP_USE_TLS=false

# --- Connection Pool ---
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# --- Request Size Limit ---
GRID_MAX_BODY_BYTES=10485760
