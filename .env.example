# ============================================================
# GRID — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=grid
DB_USER=grid_user
DB_PASSWORD=changeme

# --- API Keys ---
FRED_API_KEY=your_fred_api_key_here

# --- Logging ---
LOG_LEVEL=INFO
ENVIRONMENT=development

# --- Pull Schedule (cron format) ---
PULL_SCHEDULE_FRED=0 18 * * 1-5
PULL_SCHEDULE_YFINANCE=30 18 * * 1-5
PULL_SCHEDULE_BLS=0 9 * * *

# --- International APIs ---
KOSIS_API_KEY=your_kosis_key_here
COMTRADE_API_KEY=your_comtrade_key_here
JQUANTS_EMAIL=your_email_here
JQUANTS_PASSWORD=your_password_here

# --- USDA ---
USDA_NASS_API_KEY=your_usda_nass_key_here

# --- Pull schedules for v2 sources ---
PULL_SCHEDULE_INTERNATIONAL=0 20 * * 1-5
PULL_SCHEDULE_TRADE=0 3 * * 0
PULL_SCHEDULE_PHYSICAL=0 4 1 * *
PULL_SCHEDULE_ALTDATA=30 20 * * 1-5
