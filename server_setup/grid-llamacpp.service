[Unit]
Description=GRID llama.cpp Inference Server (Hermes 8B)
After=network.target

[Service]
Type=simple
User=grid
WorkingDirectory=/home/grid/grid_v4/grid_repo/grid
EnvironmentFile=/home/grid/grid_v4/grid_repo/grid/.env
ExecStart=/bin/bash scripts/start_llamacpp.sh
Restart=always
RestartSec=10
StandardOutput=append:/data/grid/logs/llamacpp.log
StandardError=append:/data/grid/logs/llamacpp.log

# GPU access
SupplementaryGroups=video render

[Install]
WantedBy=multi-user.target
