+        engine = MagicMock()
+        engine.connect.return_value.__enter__ = MagicMock(return_value=conn)
+        engine.connect.return_value.__exit__ = MagicMock(return_value=False)
+
+        em = EntityMap(db_engine=engine)
+        # VIXCLS -> vix_spot, not in initial cache, triggers refresh
+        result = em.get_feature_id("VIXCLS")
+        assert result == 2
+        assert call_count >= 3  # At least one refresh happened
+
+
+class TestGetAllMappings:
