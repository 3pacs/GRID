index 0000000..79b30e8
--- /dev/null
+++ b/tests/test_entity_map.py
@@ -0,0 +1,235 @@
+"""Tests for normalization/entity_map.py — EntityMap class and SEED_MAPPINGS.
+
+Covers: get_feature_id, get_all_mappings, load_v2_mappings, suggest_mapping,
+cache refresh, and SEED_MAPPINGS integrity.
+"""
+
+from __future__ import annotations
+
+from unittest.mock import MagicMock, patch
+
+import pytest
+
+from normalization.entity_map import (
+    SEED_MAPPINGS,
+    EntityMap,
+)
+
+
+# ---------------------------------------------------------------------------
+# Fixtures
+# ---------------------------------------------------------------------------
+
+class FakeRow:
+    """Minimal row object returned by fetchall()."""
+    def __init__(self, id_: int, name: str):
+        self._data = (id_, name)
+    def __getitem__(self, idx: int):
+        return self._data[idx]
+
+
+def _make_fake_engine(rows: list[tuple[int, str]] | None = None):
+    """Build a mock SQLAlchemy engine that returns given rows for SELECT."""
+    if rows is None:
+        rows = [
+            (1, "fed_funds_rate"),
+            (2, "vix_spot"),
+            (3, "sp500_close"),
+            (4, "yld_curve_2s10s"),
+            (5, "cpi_yoy"),
+        ]
+    fake_rows = [FakeRow(id_, name) for id_, name in rows]
+    conn = MagicMock()
+    conn.execute.return_value.fetchall.return_value = fake_rows
+    engine = MagicMock()
+    engine.connect.return_value.__enter__ = MagicMock(return_value=conn)
+    engine.connect.return_value.__exit__ = MagicMock(return_value=False)
+    return engine
+
+
+@pytest.fixture
+def entity_map():
+    """EntityMap with a small set of known features in the cache."""
+    engine = _make_fake_engine()
+    return EntityMap(db_engine=engine)
+
+
+# ---------------------------------------------------------------------------
+# SEED_MAPPINGS integrity
+# ---------------------------------------------------------------------------
+
+class TestSeedMappings:
+    """Validate structural integrity of the hardcoded SEED_MAPPINGS dict."""
+
+    def test_seed_mappings_is_nonempty(self):
+        assert len(SEED_MAPPINGS) > 0, "SEED_MAPPINGS should not be empty"
+
+    def test_seed_mappings_has_core_fred_codes(self):
+        core_fred = ["T10Y2Y", "DFF", "VIXCLS", "CPIAUCSL", "PAYEMS", "UNRATE"]
+        for code in core_fred:
+            assert code in SEED_MAPPINGS, f"Core FRED code '{code}' missing from SEED_MAPPINGS"
+
+    def test_seed_mappings_has_yfinance_tickers(self):
+        assert "YF:^GSPC:close" in SEED_MAPPINGS
+        assert "YF:^VIX:close" in SEED_MAPPINGS
+
+    def test_seed_mappings_values_are_strings(self):
+        for raw_id, feature_name in SEED_MAPPINGS.items():
+            assert isinstance(raw_id, str), f"Key {raw_id!r} is not a string"
+            assert isinstance(feature_name, str), f"Value for {raw_id!r} is not a string"
+
+    def test_seed_mappings_no_empty_values(self):
+        for raw_id, feature_name in SEED_MAPPINGS.items():
+            assert feature_name.strip(), f"Empty feature name for key '{raw_id}'"
+
+    def test_seed_mappings_no_empty_keys(self):
+        for raw_id in SEED_MAPPINGS:
+            assert raw_id.strip(), "Found empty key in SEED_MAPPINGS"
+
+    def test_many_to_one_is_valid(self):
+        """Multiple raw_ids can map to the same feature (e.g. vix_spot from FRED + CBOE)."""
+        values = list(SEED_MAPPINGS.values())
+        # Just verify that duplicates exist (expected) and no crash
+        assert len(values) >= len(set(values)), "Expected some many-to-one mappings"
+
+
+# ---------------------------------------------------------------------------
+# EntityMap class
+# ---------------------------------------------------------------------------
+
+class TestEntityMapInit:
+    """Test construction and cache loading."""
+
+    def test_init_loads_cache(self, entity_map: EntityMap):
+        assert len(entity_map._feature_cache) == 5
+
+    def test_init_with_empty_db(self):
+        engine = _make_fake_engine(rows=[])
+        em = EntityMap(db_engine=engine)
+        assert em._feature_cache == {}
+
+    def test_cache_maps_name_to_id(self, entity_map: EntityMap):
+        assert entity_map._feature_cache["fed_funds_rate"] == 1
+        assert entity_map._feature_cache["vix_spot"] == 2
+
+
+class TestGetFeatureId:
+    """Test get_feature_id resolution logic."""
+
+    def test_known_mapping_resolves(self, entity_map: EntityMap):
+        # DFF -> fed_funds_rate -> id 1
+        result = entity_map.get_feature_id("DFF")
+        assert result == 1
+
+    def test_vixcls_resolves_to_vix_spot(self, entity_map: EntityMap):
+        result = entity_map.get_feature_id("VIXCLS")
+        assert result == 2
+
+    def test_unknown_series_returns_none(self, entity_map: EntityMap):
+        result = entity_map.get_feature_id("TOTALLY_FAKE_SERIES_XYZ")
+        assert result is None
+
+    def test_mapped_but_not_in_registry_returns_none(self):
+        """Series has a mapping but the feature isn't in the DB."""
+        engine = _make_fake_engine(rows=[(99, "some_other_feature")])
+        em = EntityMap(db_engine=engine)
+        # T10Y2Y maps to yld_curve_2s10s, which isn't in the fake DB
+        result = em.get_feature_id("T10Y2Y")
+        assert result is None
+
+    def test_cache_refresh_on_miss(self):
+        """When a mapped feature is missing from cache, it triggers a refresh."""
+        call_count = 0
+        original_rows = [FakeRow(1, "fed_funds_rate")]
+
+        conn = MagicMock()
+
+        def side_effect(*args, **kwargs):
+            nonlocal call_count
+            call_count += 1
+            result = MagicMock()
+            if call_count <= 2:
+                # First two calls (init + load_v2): only fed_funds_rate
+                result.fetchall.return_value = original_rows
+            else:
+                # Third call (refresh): now includes vix_spot
+                result.fetchall.return_value = [
+                    FakeRow(1, "fed_funds_rate"),
