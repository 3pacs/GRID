From ab53a5b16beaa43cbf5556519a0ad2d1c7900de6 Mon Sep 17 00:00:00 2001
From: Anik Dang <anik@ocmri.com>
Date: Mon, 30 Mar 2026 22:09:45 -0700
Subject: [PATCH 2/2] fix: WebSocket auth, API key validation, entity_map tests

Security:
- WebSocket /ws now supports first-message auth pattern
- Legacy query param auth still works for backward compat
- 5-second timeout on auth handshake

Operational:
- All API keys validated at startup with warning log
- Missing keys logged with count and names

Testing:
- Add test suite for normalization/entity_map.py (20 tests)
- Covers SEED_MAPPINGS integrity, resolution, cache refresh, fuzzy matching
---
 api/main.py              |  30 ++++-
 config.py                |  11 ++
 tests/test_entity_map.py | 235 +++++++++++++++++++++++++++++++++++++++
 3 files changed, 271 insertions(+), 5 deletions(-)
 create mode 100644 tests/test_entity_map.py

diff --git a/api/main.py b/api/main.py
index 744cc39..9d11ee0 100644
--- a/api/main.py
+++ b/api/main.py
@@ -573,12 +573,13 @@ async def websocket_endpoint(
     websocket: WebSocket,
     token: str = Query(default=""),
 ) -> None:
-    """WebSocket endpoint for real-time updates."""
-    client_ip = websocket.client.host if websocket.client else "unknown"
+    """WebSocket endpoint for real-time updates.
 
-    if not token or not verify_token(token):
-        await websocket.close(code=4001, reason="Invalid token")
-        return
+    Auth: supports first-message auth (preferred) or query param (legacy).
+    First-message: connect without token, send {"type": "auth", "token": "..."} as first message.
+    Legacy: pass ?token=... in query string (deprecated — leaks to logs/proxies).
+    """
+    client_ip = websocket.client.host if websocket.client else "unknown"
 
     if not _check_ws_rate(client_ip):
         await websocket.close(code=1008, reason="Rate limit exceeded")
@@ -588,7 +589,26 @@ async def websocket_endpoint(
         await websocket.close(code=1008, reason="Server capacity exceeded")
         return
 
+    # Legacy query param auth (still supported for backward compat)
+    authenticated = bool(token and verify_token(token))
+
     await websocket.accept()
+
+    # First-message auth: if no query token, expect auth message within 5s
+    if not authenticated:
+        try:
+            raw = await asyncio.wait_for(websocket.receive_text(), timeout=5.0)
+            msg = json.loads(raw)
+            if msg.get("type") == "auth" and verify_token(msg.get("token", "")):
+                authenticated = True
+            else:
+                await websocket.send_json({"type": "error", "message": "Invalid auth"})
+                await websocket.close(code=4001, reason="Invalid token")
+                return
+        except (asyncio.TimeoutError, json.JSONDecodeError, WebSocketDisconnect):
+            await websocket.close(code=4001, reason="Auth timeout or invalid message")
+            return
+
     _ws_clients.add(websocket)
     log.info("WebSocket client connected (total={n})", n=len(_ws_clients))
 
